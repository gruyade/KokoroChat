# ===========================================
# AI Character Chat - Environment Variables
# ===========================================
# このファイルをコピーして .env を作成し、実際の値を設定してください。
# cp .env.example .env

# --- LLM設定（会話用） ---
AI_CHAT_LLM_BASE_URL=http://localhost:5000/v1
AI_CHAT_LLM_API_KEY=your-api-key-here
AI_CHAT_LLM_MODEL=your-model-name

# --- LLM設定（記憶整理用） ---
AI_CHAT_MEMORY_LLM_BASE_URL=http://localhost:5000/v1
AI_CHAT_MEMORY_LLM_API_KEY=your-api-key-here
AI_CHAT_MEMORY_LLM_MODEL=your-model-name

# --- LLM設定（思考用） ---
AI_CHAT_THOUGHT_LLM_BASE_URL=http://localhost:5000/v1
AI_CHAT_THOUGHT_LLM_API_KEY=your-api-key-here
AI_CHAT_THOUGHT_LLM_MODEL=your-model-name

# --- LLM設定（キャラクター生成用） ---
AI_CHAT_CHARGEN_LLM_BASE_URL=http://localhost:5000/v1
AI_CHAT_CHARGEN_LLM_API_KEY=your-api-key-here
AI_CHAT_CHARGEN_LLM_MODEL=your-model-name

# --- TTS設定 ---
AI_CHAT_TTS_IRODORI_BASE_URL=http://localhost:8080
AI_CHAT_TTS_VOICEPEAK_BASE_URL=http://localhost:8081
